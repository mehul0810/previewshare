{
  "name": "previewshare",
  "version": "1.0.0",
  "description": "PreviewShare lets you securely share preview links for draft, pending, or scheduled content without publishing it publicly.",
  "homepage": "https://github.com/mehul0810/previewshare#readme",
  "license": "GPL-3.0-or-later",
  "author": {
    "name": "Mehul Gohil",
    "email": "hello@mehulgohil.com",
    "url": "https://mehulgohil.com",
    "role": "developer"
  },
  "bugs": {
    "url": "https://github.com/mehul0810/previewshare/issues"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/mehul0810/previewshare.git"
  },
  "engines": {
    "node": ">=20.0.0"
  },
  "files": [
    "assets/dist",
    "config",
    "languages",
    "src",
    "vendor",
    "license.txt",
    "previewshare.php",
    "readme.txt"
  ],
  "scripts": {
    "start": "wp-scripts start --mode development",
    "prebuild": "node -e \"const major = Number(process.versions.node.split('.')[0]); if (major < 20) { console.error('PreviewShare build requires Node.js 20 or newer.'); process.exit(1); }\"",
    "build": "wp-scripts build --mode production",
    "plugin-zip": "npm run build && composer install --no-dev --no-interaction --prefer-dist --optimize-autoloader --no-progress && bash scripts/build-release-zip.sh",
    "validate:zip": "bash scripts/validate-release-zip.sh",
    "validate:wporg": "bash scripts/validate-wporg-assets.sh",
    "format": "wp-scripts format",
    "audit:prod": "npm audit --omit=dev --audit-level=moderate",
    "lint:css": "wp-scripts lint-style \"assets/src/css/**/*.css\"",
    "lint:js": "wp-scripts lint-js assets/src/js webpack.config.js wp-textdomain.js",
    "test:js": "wp-scripts test-unit-js"
  },
  "devDependencies": {
    "@babel/core": "^7.28.5",
    "@babel/preset-env": "^7.28.5",
    "@babel/preset-react": "^7.28.5",
    "@wordpress/components": "^30.9.0",
    "@wordpress/data": "^10.36.0",
    "@wordpress/edit-post": "^8.36.0",
    "@wordpress/editor": "^14.36.0",
    "@wordpress/element": "^6.36.0",
    "@wordpress/i18n": "^6.9.0",
    "@wordpress/icons": "11.3.0",
    "@wordpress/plugins": "^7.36.0",
    "@wordpress/scripts": "^31.1.0",
    "babel-loader": "^10.0.0",
    "mini-css-extract-plugin": "^2.8.1",
    "postcss-import": "^16.1.0",
    "postcss-loader": "^8.1.1",
    "postcss-nested": "^7.0.2",
    "postcss-preset-env": "^9.5.4",
    "style-loader": "^3.3.4",
    "wp-pot": "^1.10.2"
  }
}
